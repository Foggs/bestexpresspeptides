modules = ["nodejs-20", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:1.0.0", "javascript_database:1.0.0", "google-sheet:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "at-spi2-core", "atk", "cairo", "chromium", "cups", "dbus", "expat", "glib", "libdrm", "libxkbcommon", "mesa", "nspr", "nss", "pango", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb"]

[userenv]

[userenv.shared]
NEXTAUTH_SECRET = "peptidelabs-secret-key-change-in-production-123456"
NEXTAUTH_URL = "https://localhost:5000"
NEXT_PUBLIC_GA_ID = "G-XXXXXXXXXX"
GOOGLE_SHEET_ID = "1kUInxIBWDL2XdSS5WeRtrRhYzxHYzWVUiU8vNjY8dHA"
NEXT_PUBLIC_GOOGLE_SHEET_ID = "1kUInxIBWDL2XdSS5WeRtrRhYzxHYzWVUiU8vNjY8dHA"
ADMIN_EMAIL = "robfoggo@gmail.com"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Next.js Development Server"

[[workflows.workflow]]
name = "Next.js Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]
